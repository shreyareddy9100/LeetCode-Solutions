class Solution {
public:
    bool canConstruct(string ransomNote, string magazine) {

        unordered_map<char, int> freq;

        // Count characters in magazine
        for (char ch : magazine) {
            freq[ch]++;
        }

        // Check ransomNote characters
        for (char ch : ransomNote) {

            if (freq[ch] == 0) {
                return false;
            }

            freq[ch]--;
        }

        return true;
    }
};
