class Solution {
public:

    string buildString(string str) {

        string result = "";

        for (char ch : str) {

            if (ch != '#') {
                result += ch;
            }
            else if (!result.empty()) {
                result.pop_back();
            }
        }

        return result;
    }

    bool backspaceCompare(string s, string t) {

        return buildString(s) == buildString(t);
    }
};
